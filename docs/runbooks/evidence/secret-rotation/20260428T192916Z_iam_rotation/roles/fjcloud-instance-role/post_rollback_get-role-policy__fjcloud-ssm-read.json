{
    "RoleName": "fjcloud-instance-role",
    "PolicyName": "fjcloud-ssm-read",
    "PolicyDocument": {
        "Version": "2012-10-17",
        "Statement": [
            {
                "Effect": "Allow",
                "Action": [
                    "ssm:GetParameter",
                    "ssm:GetParametersByPath",
                    "ssm:PutParameter",
                    "ssm:DeleteParameter"
                ],
                "Resource": "arn:aws:ssm:*:*:parameter/fjcloud/*"
            }
        ]
    }
}

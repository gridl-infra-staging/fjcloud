  "routes": {
    "submit": {
      "method": "POST",
      "path": "/1/migrations/algolia"
    },
    "status": {
      "method": "GET",
      "path": "/1/migrations/algolia/{job_id}"
    },
    "cancel": {
      "method": "POST",
      "path": "/1/migrations/algolia/{job_id}/cancel"
    }
  },
  "required_runtime_routes": {
    "acknowledge": {
      "method": "POST",
      "path": "/1/migrations/algolia/{job_id}/acknowledge"
    }
  },
  "acknowledgement_contract": {
    "authentication": {
      "required": true,
      "headers": [
        "x-algolia-api-key",
        "x-algolia-application-id"
      ]
    },
    "durability": {
      "persisted_state": "acknowledged_before_success_response"
    },
    "idempotency": {
      "duplicate_acknowledgement": "success_no_mutation"
    },
    "absence": {
      "missing_job": {
        "http_status": 404,
        "code": "migration_job_not_found"
      }
    },
    "already_acknowledged": {
      "http_status": 204
    }
  },
  "acknowledgement_known_answer": {
    "command": [
      "bash",
      "engine/scripts/test_algolia_migration_acknowledgement_contract.sh"
    ],
    "success_marker": "PASS acknowledgement_contract authentication durability idempotency missing_job"
  },
  "request": {
    "required_fields": [
      "apiKey",
      "appId",
      "sourceIndex"
    ],
    "optional_fields": [
      "overwrite",
      "targetIndex"
    ]
  },
  "status": {
    "required_fields": [
      "createdAt",
      "disposition",
      "jobId",
      "phase",
      "updatedAt"
    ],
    "optional_fields": [
      "exportProgress",
      "terminalAt"
    ]
  },
  "progress": {
    "required_fields": [
      "completed",
      "total"
    ],
    "optional_fields": []
  },
  "enums": {
    "phase": [
      "submitted",
      "exporting",
      "preparing",
      "staging",
      "activating"
    ],
    "disposition": [
      "running",
      "succeeded",
      "failed",
      "cancelled"
    ]
  },
  "errors": {
    "migration_ha_unsupported": {
      "http_status": 503
    },

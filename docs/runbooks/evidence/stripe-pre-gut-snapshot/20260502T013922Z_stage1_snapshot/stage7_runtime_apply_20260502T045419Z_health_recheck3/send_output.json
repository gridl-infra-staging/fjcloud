        "Comment": "stage7 health retry verify",
        "ExpiresAfter": "2026-05-02T02:54:20.789000-04:00",
        "Parameters": {
            "commands": [
                "set -euo pipefail; sudo systemctl restart fjcloud-api; systemctl is-active fjcloud-api; for i in $(seq 1 30); do if curl -fsS http://127.0.0.1:3001/health >/dev/null; then echo \"health_ok_after_seconds=$i\"; break; fi; sleep 1; if [ \"$i\" -eq 30 ]; then echo \"health_timeout\" >&2; exit 7; fi; done; journalctl -u fjcloud-api --since \"10 minutes ago\" --no-pager"
            ]

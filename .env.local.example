# =============================================================================
# Flapjack Cloud Local Development Environment
# =============================================================================
# Run `scripts/bootstrap-env-local.sh` to generate .env.local from this template
# with safe random values for JWT_SECRET and ADMIN_KEY. The bootstrap is also
# auto-invoked by `scripts/local-dev-up.sh` when .env.local is missing.
# See docs/env-vars.md for the full variable reference.

# ---------------------------------------------------------------------------
# Required — API will not start without these
# ---------------------------------------------------------------------------

# Postgres connection string (matches Docker Compose credentials)
DATABASE_URL=postgres://griddle:griddle_local@localhost:5432/fjcloud_dev

# Host-side Docker bind port for Postgres. Keep this aligned with DATABASE_URL
# when you run `docker compose --env-file .env.local ...` directly.
# LOCAL_DB_PORT=5432

# Auth signing key (minimum 32 characters) — REQUIRED, replace before starting
JWT_SECRET=replace-with-32-plus-random-characters

# Bootstrap admin key (minimum 16 characters) — REQUIRED, replace before starting
ADMIN_KEY=replace-with-random-admin-key

# ---------------------------------------------------------------------------
# Production-required — local fallbacks active only when ENVIRONMENT=local and NODE_SECRET_BACKEND=memory
# ---------------------------------------------------------------------------

# Storage access key encryption (64-char hex = 32 bytes). Generate with: openssl rand -hex 32
# In local dev mode (`ENVIRONMENT=local` + `NODE_SECRET_BACKEND=memory`), a
# deterministic dev key is auto-generated when this is unset. Set explicitly
# for production.
# STORAGE_ENCRYPTION_KEY=

# Email sender — NOT required for local dev.
# When `ENVIRONMENT=local` and `NODE_SECRET_BACKEND=memory` and both are
# absent, startup uses NoopEmailService (emails logged, not sent).
# SES_FROM_ADDRESS=system@flapjack.foo
# SES_REGION=us-east-1

# ---------------------------------------------------------------------------
# API server (optional — defaults shown)
# ---------------------------------------------------------------------------

# LISTEN_ADDR=0.0.0.0:3001
ENVIRONMENT=local
# RUST_LOG=info,api=debug

# ---------------------------------------------------------------------------
# SvelteKit web portal (recommended for reliable local dev)
# ---------------------------------------------------------------------------

API_BASE_URL=http://127.0.0.1:3001

# ---------------------------------------------------------------------------
# Local S3 (SeaweedFS) — persistent cold storage replacing InMemoryObjectStore
# ---------------------------------------------------------------------------
# Setting any COLD_STORAGE_* var switches the API from InMemoryObjectStore to
# S3ObjectStore. Local SeaweedFS runs with deterministic non-secret credentials
# so real AWS credentials never get used for localhost S3 signing.
COLD_STORAGE_BUCKET=griddle-cold-storage
COLD_STORAGE_ENDPOINT=http://localhost:8333
COLD_STORAGE_REGION=us-east-1
COLD_STORAGE_ACCESS_KEY=griddle_local_s3
COLD_STORAGE_SECRET_KEY=griddle_local_s3_secret

# ---------------------------------------------------------------------------
# Local Email (Mailpit) — real email delivery to a local catch-all
# ---------------------------------------------------------------------------
# When MAILPIT_API_URL is set and SES env is absent, the API uses
# MailpitEmailService instead of NoopEmailService. Emails arrive in
# Mailpit's web UI at http://localhost:8025.
MAILPIT_API_URL=http://localhost:8025
EMAIL_FROM_ADDRESS=system@flapjack.foo
EMAIL_FROM_NAME=Flapjack Cloud Local Dev

# ---------------------------------------------------------------------------
# Stripe (optional — billing features disabled when unset)
# ---------------------------------------------------------------------------
# Set STRIPE_LOCAL_MODE=1 to enable the stateful in-process Stripe mock
# (LocalStripeService). Billing works fully offline with webhook dispatch.
STRIPE_LOCAL_MODE=1
STRIPE_WEBHOOK_SECRET=whsec_local_dev_secret
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SUCCESS_URL=http://localhost:5173/dashboard
# STRIPE_CANCEL_URL=http://localhost:5173/dashboard

# ---------------------------------------------------------------------------
# Internal auth (optional — inter-service communication)
# ---------------------------------------------------------------------------

# INTERNAL_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Local dev helpers (optional — see docs/env-vars.md "Local Development")
# ---------------------------------------------------------------------------

# Path to flapjack_dev repo (consumed by scripts/local-dev-up.sh; default: ../flapjack_dev).
# Set this explicitly when flapjack_dev is not adjacent to this repo checkout.
# FLAPJACK_DEV_DIR=../flapjack_dev

# Port flapjack binds to (consumed by scripts/local-dev-up.sh; default: 7700)
# FLAPJACK_PORT=7700

# Multi-region Flapjack: start 3 instances on different ports.
# Format: "region:port region:port ...". When set, local-dev-up.sh starts one
# Flapjack per entry and seed_local.sh points VM inventory rows at the correct URL.
# Set FLAPJACK_SINGLE_INSTANCE=1 to force single-instance mode even when this is set.
# FLAPJACK_REGIONS=us-east-1:7700 eu-west-1:7701 eu-central-1:7702

# Optional seed_local.sh override when flapjack is not on localhost:$FLAPJACK_PORT.
# Defaults to http://localhost:$FLAPJACK_PORT (7700 if FLAPJACK_PORT is unset).
# FLAPJACK_URL=http://127.0.0.1:7700

# Local-dev provisioning bypass. Creates provider=local inventory rows pointing
# at this loopback URL instead of calling cloud providers. Required for local
# index creation to work.
LOCAL_DEV_FLAPJACK_URL=http://127.0.0.1:7700

# Shared local flapjack admin key. In local dev with `ENVIRONMENT=local` and
# `NODE_SECRET_BACKEND=memory`, the API and the local flapjack process must
# agree on the same admin key for proxy requests to work. The wrapper scripts
# default this to the value below if you leave it unset.
FLAPJACK_ADMIN_KEY=fj_local_dev_admin_key_000000000000

# Local-dev auth bypass. Auto-verifies new signups instead of waiting for
# email delivery. With Mailpit configured (MAILPIT_API_URL), real emails
# arrive in the Mailpit UI so this is optional for quick local work. Leave it
# UNSET for strict local signoff when verification-email evidence matters.
SKIP_EMAIL_VERIFICATION=1

# Node secret backend (consumed by API runtime, not the wrapper script).
# Set to "memory" for local dev when AWS SSM is unavailable. Local fallbacks
# only activate when `ENVIRONMENT=local` (or `dev` / `development`) too.
NODE_SECRET_BACKEND=memory

# Full local signoff includes browser-unmocked flows plus the Phase 6 load
# harness. Keep the local-only rate limits and quotas high enough that those
# suites measure app behavior instead of tripping conservative launch defaults.
AUTH_RATE_LIMIT_RPM=120
ADMIN_RATE_LIMIT_RPM=1000
TENANT_RATE_LIMIT_RPM=5000
DEFAULT_MAX_QUERY_RPS=60
DEFAULT_MAX_WRITE_RPS=100
DEFAULT_MAX_INDEXES=100
